{
  "name": "dixie-bff",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && node scripts/copy-migrations.mjs",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit"
  },
  "_dependencyNotes": {
    "@noble/hashes": "Transitive via @0xhoneyjar/loa-hounfour — provides sha256 for audit-trail-hash and chain-bound-hash modules"
  },
  "dependencies": {
    "@0xhoneyjar/loa-hounfour": "github:0xHoneyJar/loa-hounfour#v8.7.0",
    "@hono/node-server": "^2.0.5",
    "@loa/straylight": "github:0xHoneyJar/loa-straylight#34bfff8",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-grpc": "0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-node": "0.219.0",
    "@opentelemetry/sdk-trace-node": "2.8.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "hono": "^4.12.26",
    "ioredis": "^5.11.1",
    "jose": "^6.0.0",
    "nats": "^2.29.3",
    "pg": "^8.22.0",
    "siwe": "^3.0.0",
    "viem": "^2.53.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "ws": "^8.19.0"
  }
}
