    "@opentelemetry/sdk-node": "0.213.0",
    "@opentelemetry/sdk-trace-node": "2.6.0",
    "@opentelemetry/semantic-conventions": "^1.30.0",
    "hono": "^4.12.5",
    "ioredis": "^5.10.0",
    "jose": "^6.2.1",
    "nats": "^2.29.3",
    "pg": "^8.20.0",
    "siwe": "^3.0.0",
    "viem": "^2.47.0",
    "zod": "^4.3.6"
